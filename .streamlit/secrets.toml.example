# Copy to `.streamlit/secrets.toml` and fill in the values.
# `secrets.toml` is gitignored — never commit it.

# The full URL of the target Google Sheet (must already be shared
# with the service account email below, Editor permission).
sheet_url = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit"

# Service-account JSON, key-for-key. Paste straight from the
# downloaded JSON file — keep the multi-line private_key intact,
# wrapped in triple-quoted string as below.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-private-key-id"
private_key = """-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_LINES_HERE
-----END PRIVATE KEY-----
"""
client_email = "cogs-pusher@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/cogs-pusher%40your-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
